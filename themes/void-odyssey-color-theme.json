    "tokenColors": [
        {
            "name": "Comments",
            "scope": ["comment", "punctuation.definition.comment", "string.comment"],
            "settings": { "foreground": "#4A5168", "fontStyle": "italic" }
        },
        {
            "name": "Keywords",
            "scope": [
                "keyword",
                "keyword.control",
                "keyword.operator.expression",
                "keyword.operator.new",
                "keyword.operator.logical",
                "storage",
                "storage.type",
                "storage.modifier"
            ],
            "settings": { "foreground": "#B48AFF" }
        },
        {
            "name": "Types and classes",
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "entity.name.namespace",
                "entity.other.inherited-class",
                "support.type",
                "support.class",
                "meta.return-type",
                "meta.type"
            ],
            "settings": { "foreground": "#00D4E6" }
        },
        {
            "name": "Built-in primitives",
            "scope": [
                "storage.type.primitive",
                "storage.type.built-in",
                "support.type.builtin",
                "support.type.primitive"
            ],
            "settings": { "foreground": "#00D4E6" }
        },
        {
            "name": "Strings",
            "scope": [
                "string",
                "string.quoted",
                "string.template",
                "string.regexp"
            ],
            "settings": { "foreground": "#2DD65B" }
        },
        {
            "name": "String escapes",
            "scope": ["constant.character.escape", "string source"],
            "settings": { "foreground": "#5FED83" }
        },
        {
            "name": "Numbers and language constants",
            "scope": [
                "constant.numeric",
                "constant.language",
                "constant.language.boolean",
                "constant.language.null"
            ],
            "settings": { "foreground": "#4DA8FF" }
        },
        {
            "name": "Function names",
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call entity.name.function",
                "meta.function entity.name.function"
            ],
            "settings": { "foreground": "#F0A832" }
        },
        {
            "name": "C/C++ preprocessor macros (Unreal UCLASS, UFUNCTION, UPROPERTY, USTRUCT, UENUM, UMETA, ...)",
            "scope": [
                "entity.name.function.preprocessor.c",
                "entity.name.function.preprocessor.cpp",
                "meta.preprocessor.macro.c entity.name.function",
                "meta.preprocessor.macro.cpp entity.name.function",
                "support.function.attribute.cpp",
                "meta.attribute.cpp entity.name.function"
            ],
            "settings": { "foreground": "#7A52D1" }
        },
        {
            "name": "Variables",
            "scope": ["variable", "variable.other", "variable.parameter"],
            "settings": { "foreground": "#E2E6F0" }
        },
        {
            "name": "Constants and enum members",
            "scope": [
                "variable.other.constant",
                "variable.other.enummember",
                "constant.other"
            ],
            "settings": { "foreground": "#7DC4FF" }
        },
        {
            "name": "Properties / object members",
            "scope": [
                "variable.other.property",
                "meta.object.member",
                "meta.property.object"
            ],
            "settings": { "foreground": "#E2E6F0" }
        },
        {
            "name": "Operators and punctuation",
            "scope": ["keyword.operator", "punctuation"],
            "settings": { "foreground": "#8891AA" }
        },
        {
            "name": "Preprocessor / meta",
            "scope": [
                "meta.preprocessor",
                "keyword.preprocessor",
                "keyword.control.directive",
                "entity.name.tag.preprocessor"
            ],
            "settings": { "foreground": "#8891AA" }
        },
        {
            "name": "Preprocessor strings (e.g. <header>)",
            "scope": [
                "meta.preprocessor string",
                "string.quoted.other.lt-gt.include"
            ],
            "settings": { "foreground": "#2DD65B" }
        },
        {
            "name": "HTML/XML tags",
            "scope": ["entity.name.tag", "punctuation.definition.tag"],
            "settings": { "foreground": "#B48AFF" }
        },
        {
            "name": "HTML/XML attributes",
            "scope": ["entity.other.attribute-name"],
            "settings": { "foreground": "#9A6EF0" }
        },
        {
            "name": "JSON / object keys",
            "scope": [
                "support.type.property-name",
                "meta.object-literal.key",
                "support.type.property-name.json"
            ],
            "settings": { "foreground": "#9A6EF0" }
        },
        {
            "name": "Markdown headings",
            "scope": [
                "markup.heading",
                "markup.heading entity.name",
                "entity.name.section.markdown"
            ],
            "settings": { "foreground": "#00D4E6", "fontStyle": "bold" }
        },
        {
            "name": "Markdown italic",
            "scope": ["markup.italic"],
            "settings": { "foreground": "#E2E6F0", "fontStyle": "italic" }
        },
        {
            "name": "Markdown bold",
            "scope": ["markup.bold"],
            "settings": { "foreground": "#E2E6F0", "fontStyle": "bold" }
        },
        {
            "name": "Markdown links",
            "scope": ["markup.underline.link", "string.other.link"],
            "settings": { "foreground": "#4DA8FF", "fontStyle": "underline" }
        },
        {
            "name": "Markdown inline code",
            "scope": ["markup.inline.raw", "markup.fenced_code"],
            "settings": { "foreground": "#5FED83" }
        },
        {
            "name": "Diff inserted",
            "scope": ["markup.inserted"],
            "settings": { "foreground": "#2DD65B" }
        },
        {
            "name": "Diff deleted",
            "scope": ["markup.deleted"],
            "settings": { "foreground": "#F04040" }
        },
        {
            "name": "Diff changed",
            "scope": ["markup.changed"],
            "settings": { "foreground": "#4DA8FF" }
        },
        {
            "name": "Invalid",
            "scope": ["invalid", "invalid.illegal"],
            "settings": { "foreground": "#FF6B6B" }
        }
    ],
    "semanticTokenColors": {
        "type": "#00D4E6",
        "class": "#00D4E6",
        "interface": { "foreground": "#00D4E6", "fontStyle": "italic" },
        "enum": "#00D4E6",
        "enumMember": "#7DC4FF",
        "function": "#F0A832",
        "method": "#F0A832",
        "macro": "#7A52D1",
        "macro.cpp": "#7A52D1",
        "variable": "#E2E6F0",
        "parameter": { "foreground": "#E2E6F0", "fontStyle": "italic" },
        "property": "#E2E6F0",
        "namespace": "#00D4E6",
        "keyword": "#B48AFF",
        "string": "#2DD65B",
        "number": "#4DA8FF",
        "comment": { "foreground": "#4A5168", "fontStyle": "italic" }
    }
}
